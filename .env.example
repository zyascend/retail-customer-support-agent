# Phase 0 local tau2-bench paths.
# Override these only if your local checkout lives somewhere else.
TAU2_BENCH_ROOT=/Users/theyang/Documents/ai/AgentProject/data_sources/raw/tau2-bench
TAU2_DATA_DIR=/Users/theyang/Documents/ai/AgentProject/data_sources/raw/tau2-bench/data/tau2

# Optional live smoke-test models. LiteLLM model names are supported by tau2.
AGENT_LLM_MODEL=deepseek/deepseek-chat
USER_LLM_MODEL=deepseek/deepseek-chat

# Configure only the provider you intend to use for live smoke tests.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEFAULT_AGENT_MODEL=deepseek-v4-flash
AGENT_LLM_TIMEOUT_SECONDS=30
AGENT_LLM_MAX_RETRIES=2
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=

# Current retail source and artifact output.
TAU3_RETAIL_ROOT=/Users/theyang/Documents/ai/AgentProject/data_sources/retail_customer_support_transaction_agent/current_tau3_bench
AGENT_ARTIFACT_DIR=artifacts/phase1
EVAL_ARTIFACT_DIR=artifacts/phase2
